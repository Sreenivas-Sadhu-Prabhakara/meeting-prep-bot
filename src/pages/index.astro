---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../site.config.mjs';

// ── Content the subagent fills in per product ──────────────────
const features = [
  {
    title: 'A one-page brief before every meeting',
    body: 'Our AI meeting prep engine auto-generates a sharp, one-page pre-meeting brief and drops it in your inbox before every calendar event — so you never walk in cold again.',
  },
  {
    title: 'Pulls from Google Calendar, Drive & email',
    body: 'Meeting Prep Bot connects to your Google Calendar, Drive and email, then reads the docs, threads and files that matter to assemble the full context automatically.',
  },
  {
    title: 'Attendee intel & interaction history',
    body: 'Know exactly who you are meeting. Every briefing surfaces attendee profiles, roles and your recent interaction history so relationships stay warm and informed.',
  },
  {
    title: 'Suggested talking points and agenda',
    body: 'This meeting preparation tool proposes tailored talking points and a ready-to-run agenda, turning scattered notes into a confident, structured conversation.',
  },
  {
    title: 'Automatic follow-up & action-item capture',
    body: 'After the call, your calendar AI assistant captures decisions, action items and follow-ups automatically — so nothing slips and next steps are always clear.',
  },
];

const faqs = [
  {
    q: 'What is ' + site.name + '?',
    a: 'Meeting Prep Bot is an AI meeting prep tool that reads your calendar, docs and email to auto-generate a sharp one-page briefing before every meeting — complete with attendee intel, context and suggested talking points, so you are fully prepared without lifting a finger.',
  },
  {
    q: 'Which calendars and tools does it connect to?',
    a: 'As a calendar AI assistant, Meeting Prep Bot connects to Google Calendar, Google Drive and email to pull the events, documents and threads relevant to each meeting. It builds every pre-meeting brief from these sources automatically, with more integrations on the way.',
  },
  {
    q: 'Is my meeting data private and secure?',
    a: 'Yes. Your privacy is central to Meeting Prep Bot. Data is encrypted in transit and at rest, we only access what is needed to build your meeting briefing, and we never sell or share your information. You stay in control and can disconnect any source at any time.',
  },
  {
    q: 'How much does Meeting Prep Bot cost?',
    a: 'Meeting Prep Bot is free to start — no credit card required. Sign up, connect your calendar, and begin receiving automatic meeting briefings right away. Paid plans with advanced meeting preparation features arrive as the product grows.',
  },
];

// FAQ structured data for rich results
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout>
  <script
    slot="header"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(faqJsonLd)}
  />
  <Header slot="header" />

  <!-- Hero -->
  <section class="mx-auto max-w-4xl px-6 pb-16 pt-20 text-center">
    <p class="mb-4 inline-block rounded-full bg-brand-50 px-4 py-1 text-sm font-semibold text-brand-700">
      {site.organization}
    </p>
    <h1 class="text-balance text-5xl font-extrabold tracking-tight sm:text-6xl">
      {site.tagline}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-[var(--muted)]">
      {site.description}
    </p>
    <div class="mt-10 flex justify-center gap-4">
      <a
        href="#cta"
        class="rounded-xl bg-brand-600 px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-600/20 transition hover:bg-brand-700"
        >Get started free</a
      >
      <a
        href="#features"
        class="rounded-xl border border-[var(--border)] px-7 py-3.5 text-base font-semibold transition hover:bg-[var(--card)]"
        >See how it works</a
      >
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="mx-auto max-w-6xl px-6 py-16">
    <h2 class="text-center text-3xl font-bold tracking-tight">Everything you need to prep in seconds</h2>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="rounded-2xl border border-[var(--border)] bg-[var(--card)] p-6">
            <h3 class="text-lg font-semibold">{f.title}</h3>
            <p class="mt-2 text-[var(--muted)]">{f.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="mx-auto max-w-3xl px-6 py-16">
    <h2 class="text-center text-3xl font-bold tracking-tight">Frequently asked questions</h2>
    <div class="mt-10 divide-y divide-[var(--border)]">
      {
        faqs.map((f) => (
          <details class="group py-5">
            <summary class="cursor-pointer list-none text-lg font-semibold">
              {f.q}
            </summary>
            <p class="mt-3 text-[var(--muted)]">{f.a}</p>
          </details>
        ))
      }
    </div>
  </section>

  <!-- CTA / waitlist -->
  <section id="cta" class="mx-auto max-w-3xl px-6 py-20 text-center">
    <div class="rounded-3xl border border-[var(--border)] bg-brand-600 px-8 py-14 text-white">
      <h2 class="text-3xl font-bold">Ready to try {site.name}?</h2>
      <p class="mx-auto mt-3 max-w-md text-brand-100">
        Join the waitlist and be first to auto-generate a one-page brief before every meeting. Free to start — no credit card required.
      </p>
      <!-- Replace action with a real backend/waitlist endpoint per product -->
      <form
        class="mx-auto mt-8 flex max-w-md gap-3"
        action="#"
        method="post"
        data-waitlist
      >
        <input
          type="email"
          name="email"
          required
          placeholder="you@work.com"
          class="w-full rounded-lg px-4 py-3 text-[var(--fg)]"
        />
        <button
          type="submit"
          class="whitespace-nowrap rounded-lg bg-white px-6 py-3 font-semibold text-brand-700 transition hover:bg-brand-50"
          >Join</button
        >
      </form>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
